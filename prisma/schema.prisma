datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ResidentRole {
  ADMIN
  MANAGER
  ACCOUNTANT
  SECURITY
  MAINTENANCE
  RESIDENT
}

enum ResidentStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum UnitType {
  APARTMENT
  VILLA
  SHOP
  OFFICE
}

enum UnitStatus {
  OCCUPIED
  VACANT
  MAINTENANCE
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  ESCALATED
}

model Compound {
  id         String   @id @default(uuid())
  name       String
  code       String?  @unique
  address    String?
  logoUrl    String?  @map("logo_url")
  adminEmail String   @map("admin_email")
  phone      String?
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  units             Unit[]
  residents         Resident[]
  complaints        Complaint[]
  serviceCategories ServiceCategory[]
  serviceProviders  ServiceProvider[]

  @@index([isActive])
  @@map("compounds")
}

model Unit {
  id         String     @id @default(uuid())
  compoundId String     @map("compound_id")
  compound   Compound   @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  unitNumber String     @map("unit_number")
  unitType   UnitType   @default(APARTMENT) @map("unit_type")
  floor      Int?
  areaSqm    Decimal?   @map("area_sqm") @db.Decimal(10, 2)
  status     UnitStatus @default(OCCUPIED)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  residents  Resident[]
  complaints Complaint[]

  @@unique([compoundId, unitNumber])
  @@index([compoundId])
  @@index([status])
  @@map("units")
}

model Resident {
  id                  String         @id @default(uuid())
  compoundId          String         @map("compound_id")
  compound            Compound       @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  unitId              String?        @map("unit_id")
  unit                Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  fullName            String         @map("full_name")
  phone               String
  email               String?
  passwordHash        String?        @map("password_hash")
  role                ResidentRole   @default(RESIDENT)
  status              ResidentStatus @default(PENDING)
  lastLoginAt         DateTime?      @map("last_login_at")
  passwordChangedAt   DateTime?      @map("password_changed_at")
  failedLoginAttempts Int            @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?      @map("locked_until")
  isEmailVerified     Boolean        @default(false) @map("is_email_verified")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  complaints Complaint[]

  @@unique([compoundId, phone])
  @@index([compoundId])
  @@index([unitId])
  @@index([phone])
  @@index([email])
  @@index([compoundId, email])
  @@index([role])
  @@index([status])
  @@map("residents")
}

model Complaint {
  id          String            @id @default(uuid())
  compoundId  String            @map("compound_id")
  compound    Compound          @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  residentId  String            @map("resident_id")
  resident    Resident          @relation(fields: [residentId], references: [id], onDelete: Cascade)
  unitId      String?           @map("unit_id")
  unit        Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  title       String
  description String
  priority    ComplaintPriority @default(MEDIUM)
  status      ComplaintStatus   @default(OPEN)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([compoundId])
  @@index([residentId])
  @@index([unitId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("complaints")
}

// ─── Service Directory ────────────────────────────────────────────────────────

enum ProviderStatus {
  PENDING
  ACTIVE
  INACTIVE
}

model ServiceCategory {
  id          String   @id @default(uuid())
  compoundId  String   @map("compound_id")
  compound    Compound @relation(fields: [compoundId], references: [id], onDelete: Cascade)

  name        String
  slug        String
  description String?
  icon        String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  providers   ServiceProvider[]

  @@unique([compoundId, slug])
  @@index([compoundId])
  @@index([isActive])
  @@map("service_categories")
}

model ServiceProvider {
  id             String          @id @default(uuid())
  compoundId     String          @map("compound_id")
  compound       Compound        @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  categoryId     String          @map("category_id")
  category       ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  name           String
  description    String?
  phone          String?
  whatsappPhone  String?         @map("whatsapp_phone")
  email          String?
  address        String?
  logoUrl        String?         @map("logo_url")
  coverImageUrl  String?         @map("cover_image_url")
  status         ProviderStatus  @default(PENDING)
  isFeatured     Boolean         @default(false) @map("is_featured")
  sortOrder      Int             @default(0) @map("sort_order")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([compoundId])
  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
  @@map("service_providers")
}
