datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ResidentRole {
  ADMIN
  MANAGER
  ACCOUNTANT
  SECURITY
  MAINTENANCE
  RESIDENT
}

enum ResidentStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum UnitType {
  APARTMENT
  VILLA
  SHOP
  OFFICE
}

enum UnitStatus {
  OCCUPIED
  VACANT
  MAINTENANCE
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  ESCALATED
}

model Compound {
  id          String      @id @default(uuid())
  name        String
  address     String?
  logoUrl     String?     @map("logo_url")
  adminEmail  String      @map("admin_email")
  phone       String?
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  units       Unit[]
  residents   Resident[]
  complaints  Complaint[]

  @@map("compounds")
  @@index([isActive])
}

model Unit {
  id          String      @id @default(uuid())
  compoundId  String      @map("compound_id")
  compound    Compound    @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  unitNumber  String      @map("unit_number")
  unitType    UnitType    @default(APARTMENT) @map("unit_type")
  floor       Int?
  areaSqm     Decimal?    @map("area_sqm") @db.Decimal(10, 2)
  status      UnitStatus  @default(OCCUPIED)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  residents   Resident[]
  complaints  Complaint[]

  @@unique([compoundId, unitNumber])
  @@index([compoundId])
  @@index([status])
  @@map("units")
}

model Resident {
  id           String         @id @default(uuid())
  compoundId   String         @map("compound_id")
  compound     Compound       @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  unitId       String?        @map("unit_id")
  unit         Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  fullName     String         @map("full_name")
  phone        String
  email        String?
  passwordHash String?        @map("password_hash")
  role         ResidentRole   @default(RESIDENT)
  status       ResidentStatus @default(PENDING)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  complaints   Complaint[]

  @@unique([compoundId, phone])
  @@index([compoundId])
  @@index([unitId])
  @@index([phone])
  @@index([role])
  @@index([status])
  @@map("residents")
}

model Complaint {
  id          String            @id @default(uuid())
  compoundId  String            @map("compound_id")
  compound    Compound          @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  residentId  String            @map("resident_id")
  resident    Resident          @relation(fields: [residentId], references: [id], onDelete: Cascade)
  unitId      String?           @map("unit_id")
  unit        Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  title       String
  description String
  priority    ComplaintPriority @default(MEDIUM)
  status      ComplaintStatus   @default(OPEN)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([compoundId])
  @@index([residentId])
  @@index([unitId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("complaints")
}
